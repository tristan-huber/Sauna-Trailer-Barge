                                {
                                  "atomType": "GitHubMolecule",
                                  "x": 0.335978835978836,
                                  "y": 0.6955307262569833,
                                  "uniqueID": "id-197373",
                                  "name": "Linear-Pattern",
                                  "ioValues": [
