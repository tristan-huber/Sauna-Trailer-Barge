                            }
                          ],
                          "topLevel": false,
                          "allAtoms": [
                            {
                              "atomType": "Output",
                              "x": 0.98,
                              "y": 0.5,
                              "uniqueID": "id-196038",
                              "ioValues": [
                                {
                                  "name": "number or geometry",
